# Neon PostgreSQL — pooled connection (used by the app at runtime).
# Get these from the Neon dashboard for your development branch.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/devstash?sslmode=require"

# Neon PostgreSQL — direct (unpooled) connection, used by Prisma Migrate.
# Same host without the `-pooler` suffix.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/devstash?sslmode=require"

# NextAuth
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend
RESEND_API_KEY=""

# Public base URL used to build absolute links in emails (verification / reset).
# REQUIRED in production — the app refuses to derive it from the request Host
# header there (Host is spoofable → reset-link poisoning). Optional in dev, where
# it falls back to the request origin (e.g. http://localhost:3000).
AUTH_URL=""

# Feature flags
# Require email verification for email/password sign-up. Defaults to off when
# unset — keep it off until a Resend domain is verified (the shared
# onboarding@resend.dev sender only delivers to the Resend account owner).
# Set to "true" to send verification emails and block unverified sign-in.
EMAIL_VERIFICATION_ENABLED="false"

# Upstash
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Context7 MCP API key. Referenced by .mcp.json as ${CONTEXT7_API_KEY}.
# Claude Code does NOT auto-load .env, so export this into the shell that
# launches `claude` (e.g. source .env, direnv, or your shell profile).
CONTEXT7_API_KEY=""
